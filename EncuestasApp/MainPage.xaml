<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EncuestasApp.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F5F5">

    <!-- Grid principal: contenido arriba, navbar abajo -->
    <Grid RowDefinitions="*, 70" BackgroundColor="White">
        
        <!-- ===== CONTENIDO PRINCIPAL ===== -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="30,0" Spacing="25">

                <Image Source="dotnet_bot.png"
                       HeightRequest="185"
                       Aspect="AspectFit"
                       SemanticProperties.Description="dot net bot in a hovercraft number nine" />

                <Label Text="Hello, World!"
                       Style="{StaticResource Headline}"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label Text="Welcome to &#10;.NET Multi-platform App UI"
                       Style="{StaticResource SubHeadline}"
                       SemanticProperties.HeadingLevel="Level2"
                       SemanticProperties.Description="Welcome to dot net Multi platform App U I" />

                <Button x:Name="CounterBtn"
                        Text="Click me"
                        SemanticProperties.Hint="Counts the number of times you click"
                        Clicked="OnCounterClicked"
                        HorizontalOptions="Fill" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== BARRA NAVEGACIÓN INFERIOR ===== -->
        <Grid Grid.Row="1"
              BackgroundColor="DarkGreen"
              ColumnDefinitions="*,*,80,*,*">

            <!-- Línea separadora superior -->
            <BoxView Grid.ColumnSpan="5"
                     HeightRequest="1"
                     VerticalOptions="Start"
                     Color="#E0E0E0"/>

            <!-- Botón: Home (activo) -->
            <VerticalStackLayout Grid.Column="0"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="3">
                <Image Source="icon_home.png"
                       HeightRequest="24" WidthRequest="24"
                       HorizontalOptions="Center"/>
                <Label Text="Inicio"
                       FontSize="10"
                       TextColor="#4CAF50"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Botón: Agenda -->
            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="3">
                <Image Source="icon_calendar.png"
                       HeightRequest="24" WidthRequest="24"
                       HorizontalOptions="Center"/>
                <Label Text="Agenda"
                       FontSize="10"
                       TextColor="#BDBDBD"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAgendaTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Espacio vacío para el botón "+" -->
            <BoxView Grid.Column="2" Color="DarkGreen"/>

            <!-- Botón: Sync -->
            <VerticalStackLayout Grid.Column="3"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="3">
                <Image Source="icon_sync.png"
                       HeightRequest="24" WidthRequest="24"
                       HorizontalOptions="Center"/>
                <Label Text="Sync"
                       FontSize="10"
                       TextColor="#BDBDBD"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSyncTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <!-- Botón: Perfil -->
            <VerticalStackLayout Grid.Column="4"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="3">
                <Image Source="icon_profile.png"
                       HeightRequest="24" WidthRequest="24"
                       HorizontalOptions="Center"/>
                <Label Text="Perfil"
                       FontSize="10"
                       TextColor="#BDBDBD"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPerfilTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>

        <!-- ===== BOTÓN "+" FLOTANTE ===== -->
        <Grid Grid.Row="1"
              HorizontalOptions="Center"
              VerticalOptions="Start"
              WidthRequest="70"
              HeightRequest="35"
              BackgroundColor="DarkGreen">
        </Grid>

        <Border Grid.Row="1"
                WidthRequest="60"
                HeightRequest="60"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,-20,0,0"
                BackgroundColor="#4CAF50"
                StrokeShape="RoundRectangle 30"
                Stroke="White"
                StrokeThickness="3">
            <Label Text="+"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="0,-3,0,0"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAddTapped"/>
            </Border.GestureRecognizers>
        </Border>

    </Grid>
</ContentPage>