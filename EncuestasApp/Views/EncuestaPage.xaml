                <Entry x:Name="EducacionSaludEditor" HeightRequest="120">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                    </Entry.Behaviors>
                </Entry>

                <Label Text="Referencias necesarias"/>
                <Picker x:Name="ReferenciasNecesariasPicker" >
                    <Picker.Items>
                        <x:String>Selecciona una opción</x:String>
                        <x:String>Centro de salud</x:String>
                        <x:String>Hospital</x:String>
                        <x:String>Especialista</x:String>
                    </Picker.Items>
                </Picker>
                <Entry x:Name="LugarEntry" Placeholder="Lugar *">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                    </Entry.Behaviors>
                </Entry>

                <Label Text="Visita de seguimiento *"/>
                <Picker x:Name="VisitaSeguimientoPicker" Title="Seleccione Opción"  SelectedIndexChanged="OnEventIndexChangedVisitaSeguimientoPicker">
                    <Picker.Items>

                        <x:String>Sí</x:String>
                        <x:String>No</x:String>
                    </Picker.Items>
                </Picker>
                <DatePicker x:Name="FechaSugeridaEntry" IsVisible="false" />


                <Label Text="12. Profesional que Realiza la Atención" FontAttributes="Bold" FontSize="18"/>
                <Line Stroke="#338C36" X2="{Binding Width, Source={RelativeSource Self}}" HorizontalOptions="Fill" StrokeThickness="3" />

                <Label Text="Nombre completo *"/>
                <Entry x:Name="NombreEncuestadorEntry" TextTransform="Uppercase"  Placeholder="Nombre Encuestador"   TextChanged="NombreEncuestadorEntry_TextChanged" >

                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
                          InvalidStyle="{StaticResource InvalidEntryStyle}"  
                          ValidStyle="{StaticResource ValidEntryStyle}"
                          Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
                          x:Name="NombreEncuestadorEntryAnyValidation2UpperValidation" 
                          CharacterType="UppercaseLetter" 
                          toolkit:MultiValidationBehavior.Error="Nombre completo deben ser mayusculas" 
                          RegexPattern="" />


                            <toolkit:CharactersValidationBehavior 
                       x:Name="NombreEncuestadorEntryAnyValidation" 
                       CharacterType="Any" 
                       MinimumCharacterTypeCount="3" 
                       toolkit:MultiValidationBehavior.Error="Nombre completo debe ser mayor a 3 caracteres" 
                       RegexPattern="^[A-ZÁÉÍÓÚÑ\s]+$" />
                        </toolkit:MultiValidationBehavior>

                    </Entry.Behaviors>
                </Entry>


                <Label Text="Cargo *"/>
                <Picker x:Name="CargoEncuestadorPicker"  Title="Selecciona una opción" >
                    <Picker.Items>
                        <x:String>Médico</x:String>
                        <x:String>Enfermero</x:String>
                    </Picker.Items>
                </Picker>

                <Label Text="¿Qué tanta disposición mostró la persona entrevistada hacía el brigadista? *"/>
                <Picker x:Name="DisposicionEncuestadoPicker"  Title="Selecciona una opción" >
                    <Picker.Items>
                        <x:String>Nula</x:String>
                        <x:String>Regular</x:String>
                        <x:String>Buena</x:String>
                        <x:String>Muy buena</x:String>
                    </Picker.Items>
                </Picker>

                <Button Text="Guardar" Clicked="OnGuardarClicked" BackgroundColor="#055A1C" TextColor="White"/>
                <StackLayout Padding="0,40,0,0">
                    <!-- Margin defined by a single uniform value. -->
                    <Label Margin="30" />
                    <!-- Margin defined by horizontal and vertical values. -->
                    <Label Margin="10,15" />
                    <!-- Margin defined by four distinct values that are applied to the left, top, right, and bottom. -->
                    <Label Margin="0,20,15,5" />
                </StackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="LoadingOverlay"
IsVisible="False"
BackgroundColor="#80000000"
InputTransparent="False">

            <VerticalStackLayout
  VerticalOptions="Center"
  HorizontalOptions="Center"
  Spacing="15">

                <ActivityIndicator
      IsRunning="True"
      Color="White"
      WidthRequest="50"
      HeightRequest="50"/>

                <Label Text="Guardando encuesta..."
         TextColor="White"
         FontAttributes="Bold"
         HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>