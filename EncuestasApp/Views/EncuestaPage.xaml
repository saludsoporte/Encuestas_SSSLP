<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EncuestaApp.Views.EncuestaPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:dataForm="clr-namespace:Syncfusion.Maui.DataForm;assembly=Syncfusion.Maui.DataForm" 
             xmlns:behaviors="clr-namespace:EncuestasApp.Behaviors"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             Padding="0,0,0,0">
    <ContentPage.Resources>
        <Style x:Key="InvalidEntryStyle" TargetType="Entry">
            <Setter Property="TextColor" Value="Red" />
        </Style>
        <Style x:Key="ValidEntryStyle" TargetType="Entry">
            <Setter Property="TextColor" Value="Green" />
        </Style>
    </ContentPage.Resources>
    <NavigationPage.TitleView>
    <StackLayout Padding="5,5,0,0">
        <!--<Grid >

                <Image HorizontalOptions="Start" Source="franja2.png"  Aspect="AspectFill" HeightRequest="40"  />
            </Grid>-->
        <Label Text="HISTORIA CLÍNICA DOMICILIARIA - BRIGADA DE SALUD" FontAttributes="Bold" FontSize="18"/>

    </StackLayout>
    </NavigationPage.TitleView>
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">
                <Label Text="1. Datos Generales del Paciente" FontAttributes="Bold" FontSize="18"/>
                <Line Stroke="#338C36" X2="{Binding Width, Source={RelativeSource Self}}" HorizontalOptions="Fill" StrokeThickness="3" />
                <!-->DATOS DE LA PERSONA<-->
                <Label Text="CURP *"/>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                    <Entry x:Name="CurpEntry" Placeholder="CURP" TextTransform="Uppercase" TextChanged="CurpEntry_TextChanged">
                        <Entry.Behaviors>
                            <behaviors:BloquearEmojisBehavior />
                            <toolkit:MultiValidationBehavior InvalidStyle="{StaticResource InvalidEntryStyle}"  ValidStyle="{StaticResource ValidEntryStyle}" Flags="ValidateOnValueChanged">
                                <toolkit:CharactersValidationBehavior x:Name="UpperValidation2" CharacterType="UppercaseLetter" toolkit:MultiValidationBehavior.Error="Deben ser mayusculas" RegexPattern="" />
                                <toolkit:CharactersValidationBehavior x:Name="CURPAnyValidation" CharacterType="Any" MinimumCharacterTypeCount="18" toolkit:MultiValidationBehavior.Error="18 caracteres" RegexPattern="([A-Z][AEIOUX][A-Z]{2}\d{2}(?:0[1-9]|1[0-2])(?:0[1-9]|[12]\d|3[01])[HM](?:AS|B[CS]|C[CLMSH]|D[FG]|G[TR]|HG|JC|M[CNS]|N[ETL]|OC|PL|Q[TR]|S[PLR]|T[CSL]|VZ|YN|ZS)[B-DF-HJ-NP-TV-Z]{3}[A-Z\d])(\d)$" />
                            </toolkit:MultiValidationBehavior>
                        </Entry.Behaviors>
                    </Entry>
                    <Button x:Name="GenerarCurpButton"
            Grid.Column="1"
            WidthRequest="40"
            HeightRequest="40"
            BackgroundColor="#055A1C"
            CornerRadius="20"
            IsVisible="False"
            Opacity="0"
            Scale="0.8"
            Clicked="OnGenerarCurpClicked">

                        <Button.ImageSource>
                            <FontImageSource
                FontFamily="MaterialIcons"
                Glyph="&#xe663;"  
                            Size="22"
                Color="White"/>
                        </Button.ImageSource>

                    </Button>

                </Grid>
                <Label Text="Nombre(s) *"/>

                <Entry x:Name="NombreEntry" Placeholder="Nombre completo " TextTransform="Uppercase"  TextChanged="NombreEntry_TextChanged">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior InvalidStyle="{StaticResource InvalidEntryStyle}" ValidStyle="{StaticResource ValidEntryStyle}" Flags="ValidateOnValueChanged">
                            <toolkit:CharactersValidationBehavior x:Name="UpperValidation" CharacterType="UppercaseLetter" toolkit:MultiValidationBehavior.Error="Nombre completo deben ser mayusculas" RegexPattern="" />
                            <toolkit:CharactersValidationBehavior x:Name="AnyValidation" CharacterType="Any" MinimumCharacterTypeCount="2" toolkit:MultiValidationBehavior.Error="Nombre completo debe ser mayor a 2 caracteres" RegexPattern="^[A-ZÁÉÍÓÚÑ\s]+$" />
                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>

                <Label Text="Primer Apellido *"/>

                <Entry x:Name="pApellidoEntry" Placeholder="Primer Apellido" TextTransform="Uppercase" TextChanged="NombreEntry_TextChanged">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior InvalidStyle="{StaticResource InvalidEntryStyle}" ValidStyle="{StaticResource ValidEntryStyle}" Flags="ValidateOnValueChanged">
                            <toolkit:CharactersValidationBehavior CharacterType="UppercaseLetter" toolkit:MultiValidationBehavior.Error="Debe contener solo mayúsculas" />
                            <toolkit:CharactersValidationBehavior CharacterType="Any" MinimumCharacterTypeCount="2" toolkit:MultiValidationBehavior.Error="Debe tener al menos 2 caracteres" RegexPattern="^[A-ZÁÉÍÓÚÑ\s]+$" />
                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>

                <Label Text="Segundo Apellido *"/>

                <Entry x:Name="sApellidoEntry" Placeholder="Segundo Apellido" TextTransform="Uppercase" TextChanged="NombreEntry_TextChanged">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior InvalidStyle="{StaticResource InvalidEntryStyle}" ValidStyle="{StaticResource ValidEntryStyle}" Flags="ValidateOnValueChanged">
                            <toolkit:CharactersValidationBehavior CharacterType="UppercaseLetter" toolkit:MultiValidationBehavior.Error="Debe contener solo mayúsculas" />
                            <toolkit:CharactersValidationBehavior CharacterType="Any" MinimumCharacterTypeCount="2" toolkit:MultiValidationBehavior.Error="Debe tener al menos 2 caracteres" RegexPattern="^[A-ZÁÉÍÓÚÑ\s]+$" />
                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>

                <Label Text="Género *"/>

                <Picker x:Name="GeneroPicker" Title="Selecciona una opción"   SelectedIndexChanged="OnEventIndexChangedGeneroPicker">
                    <Picker.Items>
                        <x:String>Masculino</x:String>
                        <x:String>Femenino</x:String>
                        <x:String>No binario</x:String>
                    </Picker.Items>
                </Picker>

                <Label Text="Fecha de nacimiento"/>
                <DatePicker x:Name="FechaNacimientoEntry" DateSelected="FechaNacimientoEntry_DateSelected"/>
                <Label Text="Edad"/>
                <Entry x:Name="EdadEntry" Placeholder="Edad" IsReadOnly="True">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                    </Entry.Behaviors>
                </Entry>
                <Label Text="Entidad de Nacimiento *"/>

                <Picker x:Name="EntidadPicker" Title="Selecciona una opción" SelectedIndexChanged="EntidadPicker_SelectedIndexChanged">
                    <Picker.Items>
                        <x:String>AGUASCALIENTES</x:String>
                        <x:String>BAJA CALIFORNIA</x:String>
                        <x:String>BAJA CALIFORNIA SUR</x:String>
                        <x:String>CAMPECHE</x:String>
                        <x:String>COAHUILA</x:String>
                        <x:String>COLIMA</x:String>
                        <x:String>CHIAPAS</x:String>
                        <x:String>CHIHUAHUA</x:String>
                        <x:String>CIUDAD DE MEXICO</x:String>
                        <x:String>DURANGO</x:String>
                        <x:String>GUANAJUATO</x:String>
                        <x:String>GUERRERO</x:String>
                        <x:String>HIDALGO</x:String>
                        <x:String>JALISCO</x:String>
                        <x:String>MEXICO</x:String>
                        <x:String>MICHOACAN</x:String>
                        <x:String>MORELOS</x:String>
                        <x:String>NAYARIT</x:String>
                        <x:String>NUEVO LEON</x:String>
                        <x:String>OAXACA</x:String>
                        <x:String>PUEBLA</x:String>
                        <x:String>QUERETARO</x:String>
                        <x:String>QUINTANA ROO</x:String>
                        <x:String>SAN LUIS POTOSI</x:String>
                        <x:String>SINALOA</x:String>
                        <x:String>SONORA</x:String>
                        <x:String>TABASCO</x:String>
                        <x:String>TAMAULIPAS</x:String>
                        <x:String>TLAXCALA</x:String>
                        <x:String>VERACRUZ</x:String>
                        <x:String>YUCATAN</x:String>
                        <x:String>ZACATECAS</x:String>
                        <x:String>NACIONAL</x:String>
                        <x:String>EXTRANJERO</x:String>
                    </Picker.Items>
                </Picker>


                <!--FIN DATOS DE LA PERSONA<-->

                <!--DATOS DOMICILIO<-->
                <Label Text="Código Postal *"/>
                <Entry x:Name="CodigoPostalEntry"
       Placeholder="Código Postal"
       Keyboard="Numeric"
                  
       TextChanged="OnCodigoPostalChanged">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
            InvalidStyle="{StaticResource InvalidEntryStyle}"  
            ValidStyle="{StaticResource ValidEntryStyle}"
            Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
                x:Name="CodigoPostalAnyValidation" 
                CharacterType="Any" 
                MinimumCharacterTypeCount="5" 
                MaximumCharacterTypeCount="5"
                toolkit:MultiValidationBehavior.Error="5 caracteres" 
                RegexPattern="^[0-9]+$" />
                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>





                <Label Text="Municipio *"/>
                <Picker x:Name="MunicipioPicker"
        Title="Seleccione municipio"
        ItemDisplayBinding="{Binding Municipio}"
        SelectedIndexChanged="OnMunicipioChanged" />
                <Label Text="Localidad *"/>
                <!--<Picker x:Name="LocalidadPicker"
        Title="Seleccione localidad"
        SelectedIndexChanged="OnLocalidadChanged"/>-->

                <Entry x:Name="LocalidadSelectorEntry"
       Placeholder="Seleccione localidad"
       IsReadOnly="True">
                    <Entry.GestureRecognizers>
                        <TapGestureRecognizer Tapped="AbrirBuscadorLocalidad" />
                    </Entry.GestureRecognizers>
                </Entry>


                <Label Text="Colonia *"/>

                <Entry x:Name="ColoniaSelectorEntry"
       Placeholder="Seleccione colonia"
       IsReadOnly="True">
                    <Entry.GestureRecognizers>
                        <TapGestureRecognizer Tapped="AbrirColoniaPopup"/>
                    </Entry.GestureRecognizers>
                </Entry>


                <HorizontalStackLayout Spacing="10">
                    <CheckBox x:Name="ColoniaNoEncontradaCheck"
              CheckedChanged="OnColoniaNoEncontradaChanged" />
                    <Label Text="No encuentro mi colonia"
           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
                <!--
                <Entry x:Name="ColoniaManualEntry"
       Placeholder="Escriba su colonia Ej. Balcones del Valle"
       IsVisible="False">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                    </Entry.Behaviors>
                </Entry>-->
                <!-- Colonia manual con icono de información -->
                <Grid x:Name="ColoniaManualContainer"
      IsVisible="False"
      ColumnDefinitions="*,40"
      VerticalOptions="Center"
      Margin="0,5,0,0">

                    <!-- Entry -->
                    <Entry x:Name="ColoniaManualEntry" Placeholder="Escriba su colonia" Grid.Column="0">
                        <Entry.Behaviors>
                            <behaviors:BloquearEmojisBehavior />
                        </Entry.Behaviors>
                    </Entry>

                    <Border Grid.Column="1" BackgroundColor="#E0E0E0" WidthRequest="24" HeightRequest="24" StrokeShape="RoundRectangle 12" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="i" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="#333" />

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnColoniaInfoTapped"/>
                        </Border.GestureRecognizers>

                    </Border>
                </Grid>
                <Label Text="Calle *"/>

                <Grid ColumnDefinitions="*,40"
      VerticalOptions="Center"
      Margin="0,5,0,0">

                    <!-- Entry Calle -->
                    <Entry x:Name="CallenEntry"
           Placeholder="Ej. Avenida Himno Nacional"
           Grid.Column="0">

                        <Entry.Behaviors>
                            <behaviors:BloquearEmojisBehavior />
                        </Entry.Behaviors>

                    </Entry>

                
                    <Border Grid.Column="1"
            BackgroundColor="#E0E0E0"
            WidthRequest="24"
            HeightRequest="24"
            StrokeShape="RoundRectangle 12"
            HorizontalOptions="Center"
            VerticalOptions="Center">

                        <Label Text="i"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               TextColor="#333" />

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCalleInfoTapped"/>
                        </Border.GestureRecognizers>

                    </Border>

                </Grid>

                <Label Text="No. Exterior *"/>
                <Entry x:Name="NumExteriorEntry" Placeholder="Número exterior *" Keyboard="Numeric">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
         InvalidStyle="{StaticResource InvalidEntryStyle}"  
         ValidStyle="{StaticResource ValidEntryStyle}"
         Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
             x:Name="NumExteriorAnyValidation" 
             CharacterType="Any" 
             RegexPattern="^[0-9]+$" />
                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>

                <Label Text="No. Interior"/>
                <Entry x:Name="NumInteriorEntry" Placeholder="Número interior">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                    </Entry.Behaviors>
                </Entry>
                <Label Text="Sección Electoral *"/>
                <Picker x:Name="SeccionPicker"
            Title="Seleccione sección electoral *"
            Focused="OnSeccionFocused"/>
                <HorizontalStackLayout Spacing="10">
                    <CheckBox x:Name="SeccionNoEncontradaCheck"
              CheckedChanged="OnSeccionNoEncontradaChanged" />
                    <Label Text="No encuentro mi sección"
           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <Entry x:Name="SeccionManualEntry"
       Placeholder="Sección electoral 0001 *"
       Keyboard="Numeric"
       IsVisible="False">

                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />

                        <toolkit:MultiValidationBehavior
            Flags="ValidateOnValueChanged"
            ValidStyle="{StaticResource ValidEntryStyle}"
            InvalidStyle="{StaticResource InvalidEntryStyle}">


                            <toolkit:NumericValidationBehavior
                Flags="ValidateOnValueChanged"
                MinimumValue="1"
                MaximumValue="9999"
                MaximumDecimalPlaces="0" />

                            <toolkit:CharactersValidationBehavior
                CharacterType="Digit"
                MinimumCharacterTypeCount="4"
                MaximumCharacterTypeCount="4"
                toolkit:MultiValidationBehavior.Error="Debe contener exactamente 4 dígitos" />

                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>

                <Label Text="Teléfono *"/>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Entry x:Name="TelefonoEntry" Grid.Column="0" Placeholder="Teléfono" Keyboard="Numeric" TextChanged="TelefonoEntry_TextChanged">
                        <Entry.Behaviors>
                            <behaviors:BloquearEmojisBehavior />
                            <toolkit:MultiValidationBehavior 
                    InvalidStyle="{StaticResource InvalidEntryStyle}"  
                    ValidStyle="{StaticResource ValidEntryStyle}"
                    Flags="ValidateOnValueChanged">

                                <toolkit:CharactersValidationBehavior 
                        x:Name="TelefonoEntryAnyValidation" 
                        CharacterType="Any" 
                        MinimumCharacterTypeCount="10" 
                        MaximumCharacterTypeCount="10"
                        
                        toolkit:MultiValidationBehavior.Error="10 caracteres" 
                        RegexPattern="^[0-9]+$" />
                            </toolkit:MultiValidationBehavior>
                        </Entry.Behaviors>
                    </Entry>
                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                        <CheckBox x:Name="NoTelefonoCheck" CheckedChanged="NoTelefonoCheck_CheckedChanged"/>
                        <Label Text="No tiene" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>
                <Label Text="Celular *"/>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Entry x:Name="CelularEntry" Grid.Column="0" Placeholder="Celular" Keyboard="Numeric" TextChanged="CelularEntry_TextChanged">
                        <Entry.Behaviors>
                            <behaviors:BloquearEmojisBehavior />
                            <toolkit:MultiValidationBehavior 
                    InvalidStyle="{StaticResource InvalidEntryStyle}"  
                    ValidStyle="{StaticResource ValidEntryStyle}"
                    Flags="ValidateOnValueChanged">

                                <toolkit:CharactersValidationBehavior 
                        x:Name="CelularAnyValidation"
                        CharacterType="Any" 
                        MinimumCharacterTypeCount="10" 
                        MaximumCharacterTypeCount="10"
                        
                        toolkit:MultiValidationBehavior.Error="10 caracteres" 
                        RegexPattern="^[0-9]+$" />
                            </toolkit:MultiValidationBehavior>
                        </Entry.Behaviors>
                    </Entry>
                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                        <CheckBox x:Name="NoCelularCheck" CheckedChanged="NoCelularCheck_CheckedChanged"/>
                        <Label Text="No tiene" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>



                <Label Text="Estado civil *"/>
                <Picker x:Name="EstadoCivilPicker" Title="Selecciona una opción"  >
                    <Picker.Items>
                        <x:String>Soltero/a</x:String>
                        <x:String>Casado/a</x:String>
                        <x:String>Unión libre</x:String>
                        <x:String>Viudo/a</x:String>
                    </Picker.Items>
                </Picker>
                <Label Text="Ocupación *"/>
                <Entry x:Name="OcupacionEntry" Placeholder="Ocupación" TextTransform="Uppercase" TextChanged="OcupacionEntry_TextChanged">

                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
                          InvalidStyle="{StaticResource InvalidEntryStyle}"  
                          ValidStyle="{StaticResource ValidEntryStyle}"
                          Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
                          x:Name="OcupacionEntryUpperValidation" 
                          CharacterType="UppercaseLetter" 
                          toolkit:MultiValidationBehavior.Error="Ocupación deben ser mayusculas" 
                          RegexPattern="" />


                            <toolkit:CharactersValidationBehavior 
                       x:Name="OcupacionEntry_AnyValidation" 
                       CharacterType="Any" 
                       MinimumCharacterTypeCount="2" 
                       toolkit:MultiValidationBehavior.Error="Ocupación debe ser mayor a 2 caracteres" 
                        />
                        </toolkit:MultiValidationBehavior>

                    </Entry.Behaviors>
                </Entry>


                <Label Text="¿Pertenece a algún pueblo indígena? *"/>
                <Picker x:Name="PuebloIndigenaPicker" Title="Selecciona una opción" SelectedIndexChanged="OnEventIndexChangedPuebloIndigenaPicker">
                    <Picker.Items>
                        <x:String>No</x:String>
                        <x:String>Sí</x:String>
                    </Picker.Items>
                </Picker>



                <Entry x:Name="CualPuebloIndigenaEntry" IsVisible="false" Placeholder="(En caso de ser sí) ¿Cuál?" TextChanged="CualPuebloIndigenaEntry_TextChanged">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
              InvalidStyle="{StaticResource InvalidEntryStyle}"  
              ValidStyle="{StaticResource ValidEntryStyle}"
              Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
              x:Name="CualPuebloIndigenaEntryUpperValidation" 
              CharacterType="UppercaseLetter" 
              toolkit:MultiValidationBehavior.Error="Cuál pueblo indígena deben ser mayusculas" 
              RegexPattern="" />


                            <toolkit:CharactersValidationBehavior 
           x:Name="CualPuebloIndigenaEntry_AnyValidation" 
           CharacterType="Any" 
           MinimumCharacterTypeCount="2" 
           toolkit:MultiValidationBehavior.Error="Cuál pueblo indígena debe ser mayor a 2 caracteres" 
            />
                        </toolkit:MultiValidationBehavior>

                    </Entry.Behaviors>
                </Entry>

                <Label Text="¿Habla algún idioma indígena? *"/>
                <Picker x:Name="IdiomaIndigenaPicker" Title="Selecciona una opción" SelectedIndexChanged="OnEventIndexChangedIdiomaIndigenaPicker">
                    <Picker.Items>
                        <x:String>No</x:String>
                        <x:String>Sí</x:String>
                    </Picker.Items>
                </Picker>
                <Entry x:Name="CualIdiomaIndigenaEntry" IsVisible="false"  Placeholder="(En caso de ser sí) ¿Cuál?"  TextChanged="CualIdiomaIndigenaEntry_TextChanged" >
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
                            InvalidStyle="{StaticResource InvalidEntryStyle}"  
                            ValidStyle="{StaticResource ValidEntryStyle}"
                            Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
                            x:Name="CualIdiomaIndigenaEntryUpperValidation" 
                            CharacterType="UppercaseLetter" 
                            toolkit:MultiValidationBehavior.Error="Cuál idioma indígena deben ser mayusculas" 
                            RegexPattern="" />


                            <toolkit:CharactersValidationBehavior 
                            x:Name="CualIdiomaIndigenaEntry_AnyValidation" 
                            CharacterType="Any" 
                            MinimumCharacterTypeCount="2" 
                            toolkit:MultiValidationBehavior.Error="Cuál idioma indígena debe ser mayor a 2 caracteres" 
                            />
                        </toolkit:MultiValidationBehavior>

                    </Entry.Behaviors>
                </Entry>
                <Label Text="Acompañante o familiar responsable *"/>
                <Entry x:Name="AcompananteEntry" Placeholder="Acompañante o familiar responsable" TextTransform="Uppercase" TextChanged="AcompananteEntry_TextChanged">

                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
                          InvalidStyle="{StaticResource InvalidEntryStyle}"  
                          ValidStyle="{StaticResource ValidEntryStyle}"
                          Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
                          x:Name="AcompananteEntry2UpperValidation" 
                          CharacterType="UppercaseLetter" 
                          toolkit:MultiValidationBehavior.Error="Nombre completo deben ser mayusculas" 
                          RegexPattern="" />


                            <toolkit:CharactersValidationBehavior 
                       x:Name="AcompananteEntryAnyValidation" 
                       CharacterType="Any" 
                       MinimumCharacterTypeCount="3" 
                       toolkit:MultiValidationBehavior.Error="Nombre completo debe ser mayor a 3 caracteres" 
                       RegexPattern="^[A-ZÁÉÍÓÚÑ\s]+$" />
                        </toolkit:MultiValidationBehavior>

                    </Entry.Behaviors>
                </Entry>





                <Label Text="Relación acompañante o familiar responsable *"/>

                <Picker x:Name="RelacionAcompanantePicker"
        Title="Seleccione relación">

                    <Picker.Items>
                        <x:String>Padre</x:String>
                        <x:String>Madre</x:String>
                        <x:String>Hijo a</x:String>
                        <x:String>Cuidador particular</x:String>
                        <x:String>Sin parentesco</x:String>
                    </Picker.Items>

                </Picker>
                <Label Text="Teléfono acompañante o familiar responsable *"/>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Entry x:Name="TelefonoAcompananteEntry" Grid.Column="0" Placeholder="Celular" Keyboard="Numeric">
                        <Entry.Behaviors>
                            <behaviors:BloquearEmojisBehavior />
                            <toolkit:MultiValidationBehavior 
                         InvalidStyle="{StaticResource InvalidEntryStyle}"  
                         ValidStyle="{StaticResource ValidEntryStyle}"
                         Flags="ValidateOnValueChanged">

                                <toolkit:CharactersValidationBehavior 
                             x:Name="TelefonoAcompananteEntryAnyValidation" 
                             CharacterType="Any" 
                             MinimumCharacterTypeCount="10" 
                             MaximumCharacterTypeCount="10"
             
                             toolkit:MultiValidationBehavior.Error="Teléfono debe ser de 10 caracteres" 
                             RegexPattern="^[0-9]+$" />
                            </toolkit:MultiValidationBehavior>
                        </Entry.Behaviors>
                    </Entry>

                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                        <CheckBox x:Name="NoTelAcompCheck" CheckedChanged="NoTelAcompCheck_CheckedChanged"/>
                        <Label Text="No tiene" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                </Grid>




                <Label Text="2. Antecedentes Personales" FontAttributes="Bold" FontSize="18"/>
                <Line Stroke="#338C36" X2="{Binding Width, Source={RelativeSource Self}}" HorizontalOptions="Fill" StrokeThickness="3" />

                <HorizontalStackLayout>
                    <CheckBox x:Name="HipertensionCheckBox" />
                    <Label Text="Hipertensión Arterial" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <HorizontalStackLayout>
                    <CheckBox x:Name="DiabetesCheckBox" />
                    <Label Text="Diabetes Mellitus" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout>
                    <CheckBox x:Name="ObesidadCheckBox" />
                    <Label Text="Obesidad" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout>
                    <CheckBox x:Name="EnfermedadCerdiovascularCheckBox" />
                    <Label Text="Enfermedad cardiovascular" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <HorizontalStackLayout>
                    <CheckBox x:Name="DislipidemiaCheckBox" />
                    <Label Text="Dislipidemia (Colesterol/Trigliceridos)" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout>
                    <CheckBox x:Name="AsmaCheckBox" />
                    <Label Text="Asma/EPOC" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout>
                    <CheckBox x:Name="TuberculosisCheckBox" />
                    <Label Text="Tuberculosis" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <HorizontalStackLayout>
                    <CheckBox x:Name="EpilepsiaCheckBox" />
                    <Label Text="Epilepsia" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout>
