                <Label Text="10. Impresión Diagnóstica / Problemas Identificados" FontAttributes="Bold" FontSize="18"/>
                <Line Stroke="#338C36" X2="{Binding Width, Source={RelativeSource Self}}" HorizontalOptions="Fill" StrokeThickness="3" />

                <Entry x:Name="ImpresionDiagnostica1Entry" Placeholder="1.">
                    <Entry.Behaviors>
