                <Label Text="Signos vitales:" FontSize="18"/>

                <Label Text="Tensión arterial (120/80) *"/>
                <Entry x:Name="TensionArterialEntry" Placeholder="mmHg">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                    </Entry.Behaviors>
                </Entry>

                <Label Text="Frecuencia cardiaca *"/>
                <Entry x:Name="FrecuenciaCardiacaEntry" Placeholder="lpm" Keyboard="Numeric">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
                     InvalidStyle="{StaticResource InvalidEntryStyle}"  
                     ValidStyle="{StaticResource ValidEntryStyle}"
                     Flags="ValidateOnValueChanged">

                            <toolkit:NumericValidationBehavior 
                        InvalidStyle="{StaticResource InvalidEntryStyle}"
                        ValidStyle="{StaticResource ValidEntryStyle}"
                        Flags="ValidateOnValueChanged"
                        MinimumValue="0"
                        MaximumValue="220"
                        MaximumDecimalPlaces="0" />

                            <!--<toolkit:CharactersValidationBehavior 
                         x:Name="FrecuenciaCardiacaEntryAnyValidation" 
                         CharacterType="Any" 
                         MinimumCharacterTypeCount="1" 
                         MaximumCharacterTypeCount="3"
                         toolkit:MultiValidationBehavior.Error="3 caracteres" 
                         RegexPattern="" />-->
                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>


                <Label Text="Temperatura *"/>
                <Entry x:Name="TemperaturaEntry" Placeholder="35.1°C" Keyboard="Numeric">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
                     InvalidStyle="{StaticResource InvalidEntryStyle}"  
                     ValidStyle="{StaticResource ValidEntryStyle}"
                     Flags="ValidateOnValueChanged">

                            <toolkit:NumericValidationBehavior 
                        InvalidStyle="{StaticResource InvalidEntryStyle}"
                        ValidStyle="{StaticResource ValidEntryStyle}"
                        Flags="ValidateOnValueChanged"
                        MinimumValue="35"
                        MaximumValue="40"
                        MaximumDecimalPlaces="1" />
                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>



                <Label Text="Frecuencia respiratoria *"/>
                <Entry x:Name="FrecuenciaRespiratoriaEntry" Placeholder="rpm" Keyboard="Numeric">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
                     InvalidStyle="{StaticResource InvalidEntryStyle}"  
                     ValidStyle="{StaticResource ValidEntryStyle}"
                     Flags="ValidateOnValueChanged">

                            <toolkit:NumericValidationBehavior 
                        InvalidStyle="{StaticResource InvalidEntryStyle}"
                        ValidStyle="{StaticResource ValidEntryStyle}"
                        Flags="ValidateOnValueChanged"
                        MinimumValue="0"
                        MaximumValue="40"
                        MaximumDecimalPlaces="0" />



                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>


                <Label Text="Saturación O₂ *"/>
                <Entry x:Name="SaturacionO2Entry" Placeholder="%" Keyboard="Numeric">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
                     InvalidStyle="{StaticResource InvalidEntryStyle}"  
                     ValidStyle="{StaticResource ValidEntryStyle}"
                     Flags="ValidateOnValueChanged">

                            <toolkit:NumericValidationBehavior 
                        InvalidStyle="{StaticResource InvalidEntryStyle}"
                        ValidStyle="{StaticResource ValidEntryStyle}"
                        Flags="ValidateOnValueChanged"
                        MinimumValue="10"
                        MaximumValue="100"
                        MaximumDecimalPlaces="0" />


                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>




                <!-- Peso en kg -->
                <Label Text="Peso *" />
                <Entry x:Name="PesoEntry" Placeholder="kg - ej. 68.500" Keyboard="Numeric">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
      InvalidStyle="{StaticResource InvalidEntryStyle}"  
      ValidStyle="{StaticResource ValidEntryStyle}"
      Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
          x:Name="PesoEntryDecimalValidation" 
          CharacterType="Any" 
          toolkit:MultiValidationBehavior.Error="Formato: 68.500" 
          RegexPattern="^\d{1,3}(\.\d{1,3})?$" />

                            <toolkit:NumericValidationBehavior 
          InvalidStyle="{StaticResource InvalidEntryStyle}"
          ValidStyle="{StaticResource ValidEntryStyle}"
          Flags="ValidateOnValueChanged"
          MinimumValue="1"
          MaximumValue="400"
          MaximumDecimalPlaces="3" />

                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>

                <!-- Talla en metros -->
                <Label Text="Talla *"/>
                <Entry x:Name="TallaEntry" Placeholder="metros - ej. 1.75" Keyboard="Numeric">
                    <Entry.Behaviors>
                        <behaviors:BloquearEmojisBehavior />
                        <toolkit:MultiValidationBehavior 
      InvalidStyle="{StaticResource InvalidEntryStyle}"  
      ValidStyle="{StaticResource ValidEntryStyle}"
      Flags="ValidateOnValueChanged">

                            <toolkit:CharactersValidationBehavior 
          x:Name="TallaEntryDecimalValidation" 
          CharacterType="Any" 
          toolkit:MultiValidationBehavior.Error="Formato: 1.75" 
          RegexPattern="^\d{1,2}(\.\d{1,2})?$" />

                            <toolkit:NumericValidationBehavior 
          InvalidStyle="{StaticResource InvalidEntryStyle}"
          ValidStyle="{StaticResource ValidEntryStyle}"
          Flags="ValidateOnValueChanged"
          MinimumValue="0.50"
          MaximumValue="2.50"
          MaximumDecimalPlaces="2" />

                        </toolkit:MultiValidationBehavior>
                    </Entry.Behaviors>
                </Entry>

                <!-- IMC (calculado automáticamente) -->
                <Label Text="IMC *"/>
                <Entry x:Name="ImcEntry" Placeholder="Se calculará automáticamente" IsEnabled="False" TextColor="Gray"/>

                <Picker x:Name="ImcPicker" Title="Categoría IMC" IsEnabled="False">
                    <Picker.Items>
