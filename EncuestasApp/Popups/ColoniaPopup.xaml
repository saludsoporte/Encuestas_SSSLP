<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="EncuestaApp.Popups.ColoniaPopup"
    BackgroundColor="{AppThemeBinding
        Light={StaticResource White},
        Dark={StaticResource OffBlack}}">

    <VerticalStackLayout
        Padding="20"
        Spacing="10"
        BackgroundColor="{AppThemeBinding
            Light={StaticResource White},
            Dark={StaticResource OffBlack}}">

        <!-- BUSCADOR -->
        <Entry
            Placeholder="Buscar colonia"
            TextChanged="OnSearchTextChanged"
            TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
            PlaceholderColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" />

        <!-- LISTA -->
        <CollectionView
            x:Name="ListaColonias"
            SelectionMode="Single"
            SelectionChanged="OnSeleccionChanged"
            HeightRequest="400"
            BackgroundColor="{AppThemeBinding
                Light={StaticResource White},
                Dark={StaticResource OffBlack}}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12">
                        <Label
                Text="{Binding .}"
                VerticalOptions="Center"
                TextColor="{AppThemeBinding Light={StaticResource Black},
                                            Dark={StaticResource White}}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>
</toolkit:Popup>